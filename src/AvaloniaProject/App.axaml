<Application
    x:Class="AvaloniaProject.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:u-semi="https://irihi.tech/ursa/themes/semi"
    xmlns:ap="https://yjammak.net/avalonia-project"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <ap:ViewLocator />
    </Application.DataTemplates>
    <Application.Styles>
        <semi:SemiTheme Locale="en-us" />
        <semi:SemiPopupAnimations />
        <semi:DataGridSemiTheme />
        <semi:AvaloniaEditSemiTheme />
        <u-semi:SemiTheme Locale="en-us" />
        <Style Selector="ComboBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemTemplate">
                <DataTemplate DataType="{x:Type x:Object}">
                    <TextBlock Text="{Binding}" />
                </DataTemplate>
            </Setter>
        </Style>
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <system:Double x:Key="FontSizeM">14</system:Double>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>